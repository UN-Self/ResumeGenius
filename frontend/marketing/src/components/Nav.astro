---
const navLinks = [
  { href: '/features', label: '功能介绍' },
  { href: '/pricing', label: '定价' },
  { href: '/help', label: '帮助文档' },
]

const themePresets = [
  { id: 'system', label: '跟随系统' },
  { id: 'futuristic-dark', label: '月光' },
  { id: 'futuristic-light', label: '银白' },
  { id: 'warm-editorial', label: '暖驼' },
  { id: 'quiet-luxury', label: '静奢' },
]
---

<nav class="nav-bar fixed top-0 left-0 right-0 z-50 border-b border-transparent bg-white/62 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-xl font-semibold tracking-tight text-foreground">ResumeGenius</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-150">
          {link.label}
        </a>
      ))}
      <div class="theme-menu relative" data-theme-menu>
        <button type="button" class="theme-menu-trigger" data-theme-menu-button aria-expanded="false">
          <span class="theme-menu-dot"></span>
          <span data-theme-current>跟随系统</span>
          <svg class="theme-menu-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="theme-menu-panel hidden" data-theme-menu-panel>
          {themePresets.map(preset => (
            <button type="button" class="theme-menu-option" data-theme-option={preset.id} data-theme-label={preset.label}>
              <span>{preset.label}</span>
              <span class="theme-menu-check">✓</span>
            </button>
          ))}
        </div>
      </div>
      <a href="/app"
        class="btn-primary inline-flex h-10 items-center justify-center rounded-full bg-[#007aff] px-5 text-sm font-medium text-white no-underline hover:bg-[#0067d8] active:bg-[#005bbf]">
        开始使用
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden flex items-center justify-center w-10 h-10 rounded-md hover:bg-muted transition-colors duration-150" aria-label="菜单" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-white/90 px-6 py-4 flex flex-col gap-3 backdrop-blur-xl">
    {navLinks.map(link => (
      <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors duration-150 no-underline py-1">
        {link.label}
      </a>
    ))}
    <div class="theme-menu relative" data-theme-menu>
      <button type="button" class="theme-menu-trigger w-full justify-between" data-theme-menu-button aria-expanded="false">
        <span class="inline-flex items-center gap-2">
          <span class="theme-menu-dot"></span>
          <span data-theme-current>跟随系统</span>
        </span>
        <svg class="theme-menu-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div class="theme-menu-panel hidden" data-theme-menu-panel>
        {themePresets.map(preset => (
          <button type="button" class="theme-menu-option" data-theme-option={preset.id} data-theme-label={preset.label}>
            <span>{preset.label}</span>
            <span class="theme-menu-check">✓</span>
          </button>
        ))}
      </div>
    </div>
    <a href="/app"
      class="btn-primary mt-2 inline-flex h-10 items-center justify-center rounded-full bg-[#007aff] px-5 text-sm font-medium text-white no-underline hover:bg-[#0067d8]">
      开始使用
    </a>
  </div>
</nav>

<!-- Spacer for fixed nav -->
<div class="h-16"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true' ? 'false' : 'true';
    toggle.setAttribute('aria-expanded', expanded);
    menu?.classList.toggle('hidden');
  });
</script>
