---
const steps = ['读取资料', '生成简历 HTML', '优化排版', '准备预览']
const typedResumeRows = [
  { title: '项目经历', line: 'ResumeGenius 工作台重构' },
  { title: '技术栈', line: 'React / TypeScript / AI' },
]
const features = [
  {
    title: 'AI 主动生成',
    description: '不只是润色文字，而是重构简历结构、排版与表达。',
  },
  {
    title: '模板预览工作台',
    description: '用简历图库管理项目，生成结果从第一屏就可感知。',
  },
  {
    title: '所见即所得',
    description: 'A4 画布编辑，服务端导出 PDF 与屏幕保持一致。',
  },
]
---

<section class="relative overflow-hidden px-6 pb-16 pt-14 md:pb-24 md:pt-20">
  <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
    <div class="animate-on-scroll">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-border bg-white/70 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-xl">
        <span class="h-2 w-2 rounded-full bg-[#20c997] shadow-[0_0_18px_rgba(32,201,151,0.75)]"></span>
        Futuristic AI resume workspace
      </div>
      <h1 class="gradient-text text-5xl font-semibold tracking-tight md:text-6xl">
        ResumeGenius
      </h1>
      <p class="mt-6 max-w-xl text-base leading-7 text-muted-foreground md:text-lg">
        把散乱资料变成可编辑简历。上传文件、接入 Git、补充经历，AI 会生成结构清晰、可以继续微调的 A4 简历。
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/app"
          class="btn-primary inline-flex h-12 items-center justify-center rounded-full bg-[#007aff] px-8 text-base font-medium text-white no-underline hover:bg-[#0067d8]">
          免费开始使用
        </a>
        <a href="#features"
          class="btn-secondary inline-flex h-12 items-center justify-center rounded-full border border-[#007aff]/25 bg-white/65 px-8 text-base font-medium text-[#007aff] no-underline backdrop-blur-xl hover:bg-white">
          了解更多
        </a>
      </div>
    </div>

    <div class="glass-panel animate-on-scroll rounded-[28px] p-4" style="--delay: 100ms">
      <div class="grid min-h-[480px] gap-4 lg:grid-cols-[0.85fr_1fr]">
        <div class="hero-console rounded-2xl border border-border p-4 text-white">
          <div class="mb-4 flex items-center justify-between">
            <span class="text-sm font-semibold">AI 生成管线</span>
            <span class="rounded-full bg-white/10 px-2 py-1 text-[11px] text-white/70">Generating</span>
          </div>
          <div class="space-y-3">
            {steps.map((step, index) => (
              <div class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/[0.06] px-3 py-3">
                <span class={`flex h-6 w-6 items-center justify-center rounded-full text-[11px] ${index === steps.length - 1 ? 'bg-[#6bdcff]/20 text-[#6bdcff]' : 'bg-[#9dffb0]/18 text-[#9dffb0]'}`}>
                  {index === steps.length - 1 ? '·' : '✓'}
                </span>
                <span class="text-sm text-white/86">{step}</span>
              </div>
            ))}
          </div>
          <div class="mt-5 rounded-2xl border border-white/10 bg-white/[0.04] p-3">
            <div class="mb-2 h-2 w-24 rounded bg-white/30"></div>
            <div class="h-2 w-full rounded bg-white/15"></div>
            <div class="mt-2 h-2 w-4/5 rounded bg-white/15"></div>
          </div>
        </div>

        <div class="hero-preview-shell rounded-2xl p-5">
          <div class="hero-preview-paper mx-auto h-full max-w-[310px] rounded-xl p-5 shadow-[0_22px_70px_rgba(15,23,42,0.22)]">
            <div class="hero-preview-divider mb-4 flex items-start justify-between border-b pb-3">
              <div>
                <div class="flex items-center gap-1">
                  <span class="typing-text hero-preview-text-accent mb-2 text-[12px] font-semibold leading-none" style="--typing-width: 7.2em; --typing-steps: 7; --type-delay: 80ms">
                    AI 简历优化
                  </span>
                  <span class="typing-cursor mb-2 h-3"></span>
                </div>
                <span class="typing-text hero-preview-text-muted block text-[8px] leading-none" style="--typing-width: 15em; --typing-steps: 15; --type-delay: 420ms">
                  前端工程师 · ResumeGenius
                </span>
              </div>
              <div class="hero-preview-line h-12 w-10 rounded opacity-60"></div>
            </div>
            {Array.from({ length: 6 }).map((_, index) => (
              <div class="mb-4">
                <div class="mb-2 flex items-center gap-2">
                  <span class="hero-preview-accent h-2.5 w-2.5 rounded-full"></span>
                  {index < typedResumeRows.length ? (
                    <span class="typing-text hero-preview-text-accent text-[8px] font-semibold leading-none" style={`--typing-width: ${index === 0 ? '5em' : '4em'}; --typing-steps: ${typedResumeRows[index].title.length}; --type-delay: ${860 + index * 520}ms`}>
                      {typedResumeRows[index].title}
                    </span>
                  ) : (
                    <span class="hero-preview-accent h-2 w-24 rounded opacity-80"></span>
                  )}
                </div>
                <div class="space-y-1.5">
                  {index < typedResumeRows.length ? (
                    <span class="typing-text hero-preview-text-muted block text-[7px] leading-none" style={`--typing-width: ${index === 0 ? '15em' : '14em'}; --typing-steps: ${typedResumeRows[index].line.length}; --type-delay: ${1080 + index * 520}ms`}>
                      {typedResumeRows[index].line}
                    </span>
                  ) : (
                    <div class="hero-preview-line h-1.5 w-full rounded"></div>
                  )}
                  <div class="hero-preview-line h-1.5 w-4/5 rounded"></div>
                  <div class="hero-preview-line h-1.5 w-3/5 rounded"></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="features" class="mx-auto mt-10 grid max-w-6xl grid-cols-1 gap-4 md:grid-cols-3">
    {features.map((f, index) => (
      <div class="card-hover glass-panel animate-on-scroll rounded-2xl px-6 py-5 text-left" style={`--delay: ${160 + index * 70}ms`}>
        <h3 class="font-sans font-semibold text-foreground mb-2">{f.title}</h3>
        <p class="text-sm text-muted-foreground leading-relaxed">{f.description}</p>
      </div>
    ))}
  </div>
</section>
