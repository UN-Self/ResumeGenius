---
const letters = [
  { char: 'R', motion: 'rise', delay: '-0.1s' },
  { char: 'e' },
  { char: 's', motion: 'sway', delay: '-0.7s' },
  { char: 'u' },
  { char: 'm', motion: 'pulse', delay: '-1.3s' },
  { char: 'e' },
  { char: 'G', motion: 'roll', delay: '-0.35s' },
  { char: 'e' },
  { char: 'n', motion: 'nod', delay: '-1s' },
  { char: 'i', motion: 'dot', delay: '-0.55s' },
  { char: 'u' },
  { char: 's', motion: 'sway', delay: '-1.6s' },
]

const { class: className = '' } = Astro.props
---

<h1 class={`animated-brand-title ${className}`} aria-label="ResumeGenius">
  {letters.map((letter, index) => (
    letter.motion === 'dot' ? (
      <span
        aria-hidden="true"
        class="brand-letter brand-letter-i"
        style={`--motion-delay: ${letter.delay}`}
      >
        <span class="brand-i-dot"></span>
        <span class="brand-i-stem"></span>
      </span>
    ) : (
      <span
        aria-hidden="true"
        class:list={['brand-letter', letter.motion && `brand-letter-${letter.motion}`]}
        style={`--motion-delay: ${letter.delay ?? '0ms'}`}
      >
        {letter.char}
      </span>
    )
  ))}
</h1>
