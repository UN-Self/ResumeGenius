---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

export interface Props {
  title: string
  description?: string
}

const { title, description = 'ResumeGenius - AI 辅助简历生成与优化平台' } = Astro.props
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:wght@500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      (() => {
        const presets = {
          'futuristic-dark': { mode: 'dark', palette: 'futuristic-apple' },
          'futuristic-light': { mode: 'light', palette: 'futuristic-apple' },
          'warm-editorial': { mode: 'light', palette: 'warm-editorial' },
          'quiet-luxury': { mode: 'dark', palette: 'quiet-luxury' },
        };
        const readCookie = (key) => document.cookie
          .split('; ')
          .find((item) => item.startsWith(`${key}=`))
          ?.split('=')
          .slice(1)
          .join('=');
        const normalizeThemeId = (id) => {
          return presets[id] ? id : '';
        };
        const hasManualTheme = localStorage.getItem('resume-genius-theme-manual') === 'true'
          || decodeURIComponent(readCookie('resume_theme_manual') || '') === 'true';
        const systemTheme = window.matchMedia?.('(prefers-color-scheme: dark)').matches
          ? 'futuristic-dark'
          : 'futuristic-light';
        const savedTheme = hasManualTheme
          ? normalizeThemeId(localStorage.getItem('resume-genius-theme-preset') || decodeURIComponent(readCookie('resume_theme_preset') || ''))
          : '';
        const preset = presets[savedTheme || systemTheme] || presets['futuristic-light'];
        document.documentElement.dataset.theme = preset.mode;
        document.documentElement.dataset.palette = preset.palette;
      })();
    </script>
    <title>{title} | ResumeGenius</title>
  </head>
  <body class="site-shell bg-background text-foreground font-sans antialiased">
    <canvas class="grid-ripple-canvas" aria-hidden="true"></canvas>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      // Scroll-triggered animation observer
      const animObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              animObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.animate-on-scroll').forEach((el) => animObserver.observe(el));

      const rippleCanvas = document.querySelector('.grid-ripple-canvas');
      const rippleContext = rippleCanvas?.getContext('2d');
      const rippleGridSize = 64;
      const rippleRadius = 280;
      const rippleDuration = 920;
      const rippleSampleStep = 8;
      const rippleMinInfluence = 0.006;
      const rippleInfluencePower = 1.55;

      if (rippleCanvas && rippleContext) {
        let animationFrame = 0;
        let lastMoveAt = 0;
        let pointerX = window.innerWidth / 2;
        let pointerY = window.innerHeight / 2;
        let dpr = Math.min(window.devicePixelRatio || 1, 2);

        const resizeRippleCanvas = () => {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          rippleCanvas.width = Math.floor(window.innerWidth * dpr);
          rippleCanvas.height = Math.floor(window.innerHeight * dpr);
          rippleCanvas.style.width = `${window.innerWidth}px`;
          rippleCanvas.style.height = `${window.innerHeight}px`;
          rippleContext.setTransform(dpr, 0, 0, dpr, 0, 0);
        };

        const drawSegment = (from, to, strokeStyle, alpha, lineWidth) => {
          rippleContext.globalAlpha = alpha;
          rippleContext.strokeStyle = strokeStyle;
          rippleContext.lineWidth = lineWidth;
          rippleContext.beginPath();
          rippleContext.moveTo(from[0], from[1]);
          rippleContext.lineTo(to[0], to[1]);
          rippleContext.stroke();
        };

        const drawRippleGrid = (time) => {
          const elapsed = time - lastMoveAt;
          const fade = Math.max(0, 1 - elapsed / rippleDuration);
          rippleContext.clearRect(0, 0, rippleCanvas.width / dpr, rippleCanvas.height / dpr);

          if (fade <= 0) {
            animationFrame = 0;
            return;
          }

          const styles = getComputedStyle(document.documentElement);
          const isLightTheme = document.documentElement.dataset.theme === 'light';
          const lineColor = styles.getPropertyValue('--color-primary').trim()
            || styles.getPropertyValue('--color-border-glow').trim()
            || '#6bdcff';
          const amplitude = 11 * fade;
          const verticalAlpha = isLightTheme ? 0.34 : 0.3;
          const horizontalAlpha = isLightTheme ? 0.28 : 0.24;
          const left = Math.floor((pointerX - rippleRadius) / rippleGridSize) * rippleGridSize;
          const right = pointerX + rippleRadius;
          const top = Math.floor((pointerY - rippleRadius) / rippleGridSize) * rippleGridSize;
          const bottom = pointerY + rippleRadius;

          rippleContext.save();
          rippleContext.lineCap = 'round';
          rippleContext.lineJoin = 'round';

          for (let x = left; x <= right; x += rippleGridSize) {
            let previous = null;
            for (let y = pointerY - rippleRadius; y <= pointerY + rippleRadius; y += rippleSampleStep) {
              const dx = x - pointerX;
              const dy = y - pointerY;
              const distance = Math.hypot(dx, dy);
              const influence = Math.max(0, 1 - distance / rippleRadius) ** rippleInfluencePower;
              const bend = Math.sin(dy * 0.055 + time * 0.006) * amplitude * influence;
              const current = [x + bend, y, influence];
              if (previous && previous[2] > rippleMinInfluence && influence > rippleMinInfluence) {
                const segmentInfluence = ((previous[2] + influence) / 2) ** 1.08;
                drawSegment(previous, current, lineColor, verticalAlpha * fade * segmentInfluence, 1.05);
              }
              previous = current;
            }
          }

          for (let y = top; y <= bottom; y += rippleGridSize) {
            let previous = null;
            for (let x = pointerX - rippleRadius; x <= pointerX + rippleRadius; x += rippleSampleStep) {
              const dx = x - pointerX;
              const dy = y - pointerY;
              const distance = Math.hypot(dx, dy);
              const influence = Math.max(0, 1 - distance / rippleRadius) ** rippleInfluencePower;
              const bend = Math.sin(dx * 0.055 + time * 0.006) * amplitude * influence;
              const current = [x, y + bend, influence];
              if (previous && previous[2] > rippleMinInfluence && influence > rippleMinInfluence) {
                const segmentInfluence = ((previous[2] + influence) / 2) ** 1.08;
                drawSegment(previous, current, lineColor, horizontalAlpha * fade * segmentInfluence, 1);
              }
              previous = current;
            }
          }

          rippleContext.restore();
          animationFrame = window.requestAnimationFrame(drawRippleGrid);
        };

        const handleGridRipplePointer = (event) => {
          pointerX = event.clientX;
          pointerY = event.clientY;
          lastMoveAt = performance.now();
          if (!animationFrame) animationFrame = window.requestAnimationFrame(drawRippleGrid);
        };

        resizeRippleCanvas();
        window.addEventListener('resize', resizeRippleCanvas);
        window.addEventListener('pointermove', handleGridRipplePointer, { passive: true });
      }

      const themePresets = {
        'futuristic-dark': { mode: 'dark', palette: 'futuristic-apple' },
        'futuristic-light': { mode: 'light', palette: 'futuristic-apple' },
        'warm-editorial': { mode: 'light', palette: 'warm-editorial' },
        'quiet-luxury': { mode: 'dark', palette: 'quiet-luxury' },
      };
      const SYSTEM_THEME_ID = 'system';

      const readThemeCookie = (key) => document.cookie
        .split('; ')
        .find((item) => item.startsWith(`${key}=`))
        ?.split('=')
        .slice(1)
        .join('=');

      const normalizeThemeId = (id) => {
        return themePresets[id] ? id : '';
      };

      const getSystemTheme = () => window.matchMedia?.('(prefers-color-scheme: dark)').matches
        ? 'futuristic-dark'
        : 'futuristic-light';

      const hasManualTheme = () => localStorage.getItem('resume-genius-theme-manual') === 'true'
        || decodeURIComponent(readThemeCookie('resume_theme_manual') || '') === 'true';

      const getInitialThemeChoice = () => {
        if (!hasManualTheme()) return SYSTEM_THEME_ID;
        return normalizeThemeId(
          localStorage.getItem('resume-genius-theme-preset')
            || decodeURIComponent(readThemeCookie('resume_theme_preset') || ''),
        ) || SYSTEM_THEME_ID;
      };

      const getEffectiveTheme = (id) => {
        if (id === SYSTEM_THEME_ID) return getSystemTheme();
        return normalizeThemeId(id) || getSystemTheme();
      };

      const setThemeAttributes = (id) => {
        const preset = themePresets[getEffectiveTheme(id)] || themePresets['futuristic-light'];
        document.documentElement.dataset.theme = preset.mode;
        document.documentElement.dataset.palette = preset.palette;
      };

      const applyThemePreset = (id) => {
        if (id === SYSTEM_THEME_ID) {
          setThemeAttributes(SYSTEM_THEME_ID);
          localStorage.setItem('resume-genius-theme-preset', SYSTEM_THEME_ID);
          localStorage.setItem('resume-genius-theme-manual', 'false');
          document.cookie = `resume_theme_preset=${encodeURIComponent(SYSTEM_THEME_ID)}; path=/; max-age=31536000; SameSite=Lax`;
          document.cookie = 'resume_theme_manual=false; path=/; max-age=31536000; SameSite=Lax';
          return;
        }

        const nextTheme = normalizeThemeId(id) || getSystemTheme();
        setThemeAttributes(nextTheme);
        localStorage.setItem('resume-genius-theme-preset', nextTheme);
        localStorage.setItem('resume-genius-theme-manual', 'true');
        document.cookie = `resume_theme_preset=${encodeURIComponent(nextTheme)}; path=/; max-age=31536000; SameSite=Lax`;
        document.cookie = 'resume_theme_manual=true; path=/; max-age=31536000; SameSite=Lax';
      };

      const initialTheme = getInitialThemeChoice();

      const closeThemeMenus = () => {
        document.querySelectorAll('[data-theme-menu]').forEach((menu) => {
          menu.querySelector('[data-theme-menu-button]')?.setAttribute('aria-expanded', 'false');
          menu.querySelector('[data-theme-menu-panel]')?.classList.add('hidden');
        });
      };

      const syncThemeMenus = (id) => {
        document.querySelectorAll('[data-theme-menu]').forEach((menu) => {
          const activeOption = menu.querySelector(`[data-theme-option="${id}"]`);
          const current = menu.querySelector('[data-theme-current]');
          if (current && activeOption) current.textContent = activeOption.getAttribute('data-theme-label') || '月光';
          menu.querySelectorAll('[data-theme-option]').forEach((option) => {
            option.classList.toggle('is-active', option.getAttribute('data-theme-option') === id);
          });
        });
      };

      document.querySelectorAll('[data-theme-menu]').forEach((menu) => {
        const trigger = menu.querySelector('[data-theme-menu-button]');
        const panel = menu.querySelector('[data-theme-menu-panel]');
        trigger?.addEventListener('click', (event) => {
          event.stopPropagation();
          const willOpen = trigger.getAttribute('aria-expanded') !== 'true';
          closeThemeMenus();
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          panel?.classList.toggle('hidden', !willOpen);
        });
        menu.querySelectorAll('[data-theme-option]').forEach((option) => {
          option.addEventListener('click', () => {
            const nextTheme = option.getAttribute('data-theme-option') || 'futuristic-dark';
            applyThemePreset(nextTheme);
            syncThemeMenus(nextTheme === SYSTEM_THEME_ID ? SYSTEM_THEME_ID : normalizeThemeId(nextTheme) || SYSTEM_THEME_ID);
            closeThemeMenus();
          });
        });
      });

      setThemeAttributes(initialTheme);
      syncThemeMenus(initialTheme);
      document.addEventListener('click', closeThemeMenus);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeThemeMenus();
      });

      window.addEventListener('storage', (event) => {
        if (event.key !== 'resume-genius-theme-preset' && event.key !== 'resume-genius-theme-manual') return;
        const nextTheme = getInitialThemeChoice();
        setThemeAttributes(nextTheme);
        syncThemeMenus(nextTheme);
      });

      window.matchMedia?.('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (hasManualTheme()) return;
        setThemeAttributes(SYSTEM_THEME_ID);
        syncThemeMenus(SYSTEM_THEME_ID);
      });

      // Nav scroll border
      const nav = document.querySelector('.nav-bar');
      if (nav) {
        const updateNav = () => {
          nav.classList.toggle('nav-scrolled', window.scrollY > 10);
        };
        window.addEventListener('scroll', updateNav, { passive: true });
        updateNav();
      }

      // FAQ smooth toggle (grid-template-rows)
      // Intercept <summary> click to prevent native toggle, manually animate via grid-template-rows
      document.querySelectorAll('details').forEach((detail) => {
        const content = detail.querySelector('.faq-content');
        const summary = detail.querySelector('summary');
        if (!content || !summary) return;

        summary.addEventListener('click', (e) => {
          if (!detail.open) {
            // Opening: prevent native toggle, manually set open, then animate after paint
            e.preventDefault();
            detail.open = true;
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                content.classList.add('open');
              });
            });
          } else {
            // Closing: prevent native toggle, animate out, then close
            e.preventDefault();
            content.classList.remove('open');
            const onEnd = () => { detail.open = false; };
            content.addEventListener('transitionend', onEnd, { once: true });
            // Fallback: transitionend won't fire if transition is skipped (e.g. reduced-motion)
            setTimeout(() => {
              content.removeEventListener('transitionend', onEnd);
              detail.open = false;
            }, 400);
          }
        });
      });
    </script>

    <!-- Auth check for user menu (API is proxied by Astro dev server) -->
    <script is:inline>
      (function(){
        var container = document.getElementById('user-menu-container');
        if (!container) return;

        var loginBtnHtml = '<a href="/app/login?redirect=/" class="btn-primary inline-flex h-10 items-center justify-center rounded-full px-5 text-sm font-medium text-white no-underline hover:brightness-110 active:brightness-90" style="background:var(--color-primary)">登录</a>';

        fetch('/api/v1/auth/me', { credentials: 'include' })
          .then(function(r){ return r.json(); })
          .then(function(json){
            if (json.code === 0) {
              var user = json.data;
              var initial = (user.username || '?').charAt(0).toUpperCase();
              container.innerHTML =
                '<div class="user-menu relative shrink-0">' +
                '<button class="user-menu-btn relative flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] text-sm font-bold text-white transition-all duration-200 hover:scale-105 active:scale-95" style="box-shadow:0 0 14px color-mix(in srgb,var(--color-primary),transparent 55%)" title="' + user.username + '">' + initial + '</button>' +
                '<div class="user-menu-dropdown absolute right-0 top-full z-50 mt-2 hidden w-52 origin-top-right rounded-2xl border border-[var(--color-border)] bg-[var(--color-popover)]/95 p-1.5 shadow-[0_20px_60px_rgba(2,8,23,0.28)] backdrop-blur-2xl">' +
                '<div class="px-3 py-2 text-sm font-medium truncate" style="color:var(--color-foreground)">' + user.username + '</div>' +
                '<div class="my-1 h-px" style="background:var(--color-border)"></div>' +
                '<a href="/app/profile" class="flex w-full items-center gap-2.5 rounded-lg px-3 py-2 text-sm no-underline transition-colors" style="color:var(--color-muted-foreground)">' +
                '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/></svg> 个人中心</a>' +
                '<button class="user-logout-btn flex w-full items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors" style="color:var(--color-muted-foreground)">' +
                '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg> 退出登录</button>' +
                '</div></div>';

              var btn = container.querySelector('.user-menu-btn');
              var dd = container.querySelector('.user-menu-dropdown');
              btn.addEventListener('click', function(e){ e.stopPropagation(); dd.classList.toggle('hidden'); });
              document.addEventListener('click', function(){ dd.classList.add('hidden'); });

              container.querySelector('.user-menu-dropdown a').addEventListener('mouseenter', function(){ this.style.backgroundColor='var(--color-surface-hover)'; this.style.color='var(--color-foreground)'; });
              container.querySelector('.user-menu-dropdown a').addEventListener('mouseleave', function(){ this.style.backgroundColor=''; this.style.color='var(--color-muted-foreground)'; });
              container.querySelector('.user-logout-btn').addEventListener('mouseenter', function(){ this.style.backgroundColor='color-mix(in srgb, var(--color-destructive), transparent 90%)'; this.style.color='var(--color-destructive)'; });
              container.querySelector('.user-logout-btn').addEventListener('mouseleave', function(){ this.style.backgroundColor=''; this.style.color='var(--color-muted-foreground)'; });

              container.querySelector('.user-logout-btn').addEventListener('click', function(){
                fetch('/api/v1/auth/logout', { method: 'POST', credentials: 'include' }).then(function(){
                  window.location.reload();
                });
              });
            } else {
              container.innerHTML = loginBtnHtml;
            }
          })
          .catch(function(){ container.innerHTML = loginBtnHtml; });
      })();
    </script>
  </body>
</html>
