---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

export interface Props {
  title: string
  description?: string
}

const { title, description = 'ResumeGenius - AI 辅助简历生成与优化平台' } = Astro.props
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:wght@500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      (() => {
        const presets = {
          'futuristic-dark': { mode: 'dark', palette: 'futuristic-apple' },
          'futuristic-light': { mode: 'light', palette: 'futuristic-apple' },
          'warm-editorial': { mode: 'light', palette: 'warm-editorial' },
          'quiet-luxury': { mode: 'dark', palette: 'quiet-luxury' },
        };
        const readCookie = (key) => document.cookie
          .split('; ')
          .find((item) => item.startsWith(`${key}=`))
          ?.split('=')
          .slice(1)
          .join('=');
        const normalizeThemeId = (id) => {
          return presets[id] ? id : '';
        };
        const hasManualTheme = localStorage.getItem('resume-genius-theme-manual') === 'true'
          || decodeURIComponent(readCookie('resume_theme_manual') || '') === 'true';
        const systemTheme = window.matchMedia?.('(prefers-color-scheme: dark)').matches
          ? 'futuristic-dark'
          : 'futuristic-light';
        const savedTheme = hasManualTheme
          ? normalizeThemeId(localStorage.getItem('resume-genius-theme-preset') || decodeURIComponent(readCookie('resume_theme_preset') || ''))
          : '';
        const preset = presets[savedTheme || systemTheme] || presets['futuristic-light'];
        document.documentElement.dataset.theme = preset.mode;
        document.documentElement.dataset.palette = preset.palette;
      })();
    </script>
    <title>{title} | ResumeGenius</title>
  </head>
  <body class="site-shell bg-background text-foreground font-sans antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      // Scroll-triggered animation observer
      const animObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              animObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );
      document.querySelectorAll('.animate-on-scroll').forEach((el) => animObserver.observe(el));

      const themePresets = {
        'futuristic-dark': { mode: 'dark', palette: 'futuristic-apple' },
        'futuristic-light': { mode: 'light', palette: 'futuristic-apple' },
        'warm-editorial': { mode: 'light', palette: 'warm-editorial' },
        'quiet-luxury': { mode: 'dark', palette: 'quiet-luxury' },
      };
      const SYSTEM_THEME_ID = 'system';

      const readThemeCookie = (key) => document.cookie
        .split('; ')
        .find((item) => item.startsWith(`${key}=`))
        ?.split('=')
        .slice(1)
        .join('=');

      const normalizeThemeId = (id) => {
        return themePresets[id] ? id : '';
      };

      const getSystemTheme = () => window.matchMedia?.('(prefers-color-scheme: dark)').matches
        ? 'futuristic-dark'
        : 'futuristic-light';

      const hasManualTheme = () => localStorage.getItem('resume-genius-theme-manual') === 'true'
        || decodeURIComponent(readThemeCookie('resume_theme_manual') || '') === 'true';

      const getInitialThemeChoice = () => {
        if (!hasManualTheme()) return SYSTEM_THEME_ID;
        return normalizeThemeId(
          localStorage.getItem('resume-genius-theme-preset')
            || decodeURIComponent(readThemeCookie('resume_theme_preset') || ''),
        ) || SYSTEM_THEME_ID;
      };

      const getEffectiveTheme = (id) => {
        if (id === SYSTEM_THEME_ID) return getSystemTheme();
        return normalizeThemeId(id) || getSystemTheme();
      };

      const setThemeAttributes = (id) => {
        const preset = themePresets[getEffectiveTheme(id)] || themePresets['futuristic-light'];
        document.documentElement.dataset.theme = preset.mode;
        document.documentElement.dataset.palette = preset.palette;
      };

      const applyThemePreset = (id) => {
        if (id === SYSTEM_THEME_ID) {
          setThemeAttributes(SYSTEM_THEME_ID);
          localStorage.setItem('resume-genius-theme-preset', SYSTEM_THEME_ID);
          localStorage.setItem('resume-genius-theme-manual', 'false');
          document.cookie = `resume_theme_preset=${encodeURIComponent(SYSTEM_THEME_ID)}; path=/; max-age=31536000; SameSite=Lax`;
          document.cookie = 'resume_theme_manual=false; path=/; max-age=31536000; SameSite=Lax';
          return;
        }

        const nextTheme = normalizeThemeId(id) || getSystemTheme();
        setThemeAttributes(nextTheme);
        localStorage.setItem('resume-genius-theme-preset', nextTheme);
        localStorage.setItem('resume-genius-theme-manual', 'true');
        document.cookie = `resume_theme_preset=${encodeURIComponent(nextTheme)}; path=/; max-age=31536000; SameSite=Lax`;
        document.cookie = 'resume_theme_manual=true; path=/; max-age=31536000; SameSite=Lax';
      };

      const initialTheme = getInitialThemeChoice();

      const closeThemeMenus = () => {
        document.querySelectorAll('[data-theme-menu]').forEach((menu) => {
          menu.querySelector('[data-theme-menu-button]')?.setAttribute('aria-expanded', 'false');
          menu.querySelector('[data-theme-menu-panel]')?.classList.add('hidden');
        });
      };

      const syncThemeMenus = (id) => {
        document.querySelectorAll('[data-theme-menu]').forEach((menu) => {
          const activeOption = menu.querySelector(`[data-theme-option="${id}"]`);
          const current = menu.querySelector('[data-theme-current]');
          if (current && activeOption) current.textContent = activeOption.getAttribute('data-theme-label') || '科技夜';
          menu.querySelectorAll('[data-theme-option]').forEach((option) => {
            option.classList.toggle('is-active', option.getAttribute('data-theme-option') === id);
          });
        });
      };

      document.querySelectorAll('[data-theme-menu]').forEach((menu) => {
        const trigger = menu.querySelector('[data-theme-menu-button]');
        const panel = menu.querySelector('[data-theme-menu-panel]');
        trigger?.addEventListener('click', (event) => {
          event.stopPropagation();
          const willOpen = trigger.getAttribute('aria-expanded') !== 'true';
          closeThemeMenus();
          trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          panel?.classList.toggle('hidden', !willOpen);
        });
        menu.querySelectorAll('[data-theme-option]').forEach((option) => {
          option.addEventListener('click', () => {
            const nextTheme = option.getAttribute('data-theme-option') || 'futuristic-dark';
            applyThemePreset(nextTheme);
            syncThemeMenus(nextTheme === SYSTEM_THEME_ID ? SYSTEM_THEME_ID : normalizeThemeId(nextTheme) || SYSTEM_THEME_ID);
            closeThemeMenus();
          });
        });
      });

      setThemeAttributes(initialTheme);
      syncThemeMenus(initialTheme);
      document.addEventListener('click', closeThemeMenus);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeThemeMenus();
      });

      window.addEventListener('storage', (event) => {
        if (event.key !== 'resume-genius-theme-preset' && event.key !== 'resume-genius-theme-manual') return;
        const nextTheme = getInitialThemeChoice();
        setThemeAttributes(nextTheme);
        syncThemeMenus(nextTheme);
      });

      window.matchMedia?.('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (hasManualTheme()) return;
        setThemeAttributes(SYSTEM_THEME_ID);
        syncThemeMenus(SYSTEM_THEME_ID);
      });

      // Nav scroll border
      const nav = document.querySelector('.nav-bar');
      if (nav) {
        const updateNav = () => {
          nav.classList.toggle('nav-scrolled', window.scrollY > 10);
        };
        window.addEventListener('scroll', updateNav, { passive: true });
        updateNav();
      }

      // FAQ smooth toggle (grid-template-rows)
      // Intercept <summary> click to prevent native toggle, manually animate via grid-template-rows
      document.querySelectorAll('details').forEach((detail) => {
        const content = detail.querySelector('.faq-content');
        const summary = detail.querySelector('summary');
        if (!content || !summary) return;

        summary.addEventListener('click', (e) => {
          if (!detail.open) {
            // Opening: prevent native toggle, manually set open, then animate after paint
            e.preventDefault();
            detail.open = true;
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                content.classList.add('open');
              });
            });
          } else {
            // Closing: prevent native toggle, animate out, then close
            e.preventDefault();
            content.classList.remove('open');
            const onEnd = () => { detail.open = false; };
            content.addEventListener('transitionend', onEnd, { once: true });
            // Fallback: transitionend won't fire if transition is skipped (e.g. reduced-motion)
            setTimeout(() => {
              content.removeEventListener('transitionend', onEnd);
              detail.open = false;
            }, 400);
          }
        });
      });
    </script>
  </body>
</html>
