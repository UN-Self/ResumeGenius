# Docker 网络
DOCKER_SUBNET=10.200.0.0/16

# PostgreSQL
PGVECTOR_IMAGE=docker.1ms.run/ankane/pgvector:latest
POSTGRES_DB=resume_genius
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
HOST_POSTGRES_PORT=5432

# Backend (Go)
GO_BUILDER_IMAGE=docker.1ms.run/golang:1.25-alpine
ALPINE_RUNTIME_IMAGE=docker.1ms.run/alpine:3.19
HOST_BACKEND_PORT=8080
JWT_SECRET=please-change-me
JWT_TTL_HOURS=8760
COOKIE_SECURE=false

# AI 模型（OpenAI-compatible API）
USE_MOCK=false
AI_API_URL=
AI_API_KEY=
AI_MODEL=

# 前端 Workbench (React)
HOST_WORKBENCH_PORT=3000

# 营销站 Marketing (Astro)
HOST_MARKETING_PORT=4321

# 时区
TZ=Asia/Shanghai
