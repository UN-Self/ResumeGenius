# Docker 网络
DOCKER_SUBNET=10.200.0.0/16

# PostgreSQL
PGVECTOR_IMAGE=docker.1ms.run/ankane/pgvector:latest
POSTGRES_DB=resume_genius
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
HOST_POSTGRES_PORT=45432

# Backend (Go)
GO_BUILDER_IMAGE=docker.1ms.run/golang:1.25-alpine
ALPINE_RUNTIME_IMAGE=docker.1ms.run/alpine:3.19
HOST_BACKEND_PORT=44480
JWT_SECRET=please-change-me
JWT_TTL_HOURS=8760
COOKIE_SECURE=false

# AI 模型（OpenAI-compatible API）
USE_MOCK=false
AI_API_URL=https://api.unself.cn
AI_API_KEY=sk-your-api-key-here
AI_MODEL=default
AGENT_MAX_ITERATIONS=10

# 前端 Workbench (React)
HOST_WORKBENCH_PORT=43000

# 营销站 Marketing (Astro)
HOST_MARKETING_PORT=44321

# 时区
TZ=Asia/Shanghai

# SMTP 邮箱验证（留空使用开发模式，验证码显示在页面上）
# 支持 QQ邮箱、163、Gmail、飞书 等任意标准 SMTP 服务
SMTP_HOST=smtp.feishu.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM=noreply@your-domain.com
