DB_PORT=45432
DB_USER=unself
DB_PASSWORD=unself
DB_NAME=resume_genius

# File upload directory
UPLOAD_DIR=./uploads

# Server port
PORT=8080

# AI mock mode (true = use mock responses, no real AI API calls)
USE_MOCK=false

# AI API (OpenAI-compatible)
